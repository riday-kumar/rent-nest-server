model Payment {
    id            String @id @default(uuid())
    rentRequestId String @unique
    transactionId String @unique

    amount Decimal
    status PaymentStatus @default(PENDING)

    // method   String?
    // currency String?

    // payment details
    meta Json?

    rentRequest RentRequest @relation(fields: [rentRequestId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("payments")
}
